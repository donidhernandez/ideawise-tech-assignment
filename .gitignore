# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# Cross-cutting rules only — per-tier ignores live in:
#   apps/server/.gitignore   (Symfony: /var/, /vendor/, .env.local, …)
#   apps/web/.gitignore      (Vite + Playwright artifacts)
#   apps/mobile/.gitignore   (Expo: .expo/, generated /ios/, /android/, …)

# Dependencies
node_modules
.pnp
.pnp.js

# Local env files (any "real" .env carries developer secrets;
# tracked `.env.example` / `.env.test` / `.env.dev` are NOT matched).
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
build
dist
out/
.next/

# Testing
coverage
**/coverage/

# Turborepo
.turbo

# Vercel
.vercel

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS metadata
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Misc
*.pem
