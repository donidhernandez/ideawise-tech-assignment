# IMPORTANT: do NOT use http://localhost or 127.0.0.1 here.
# The physical device cannot route to your computer's loopback interface.
# Use your machine's LAN IP, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

EXPO_PUBLIC_USER_ID=mobile-demo-user
EXPO_PUBLIC_CHUNK_SIZE=1048576
EXPO_PUBLIC_CONCURRENCY=3
EXPO_PUBLIC_MAX_RETRIES=3
