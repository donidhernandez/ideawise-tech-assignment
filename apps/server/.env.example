APP_ENV=dev
APP_SECRET=change_me_in_production

# SQLite (default — file in var/)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"

# CORS — adjust to your frontend origins
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Lock store (flock = file lock, no external service needed)
LOCK_DSN=flock

# Maximum upload size in bytes (default: 500 MB)
MAX_UPLOAD_SIZE=524288000

# Chunk size in bytes (must match client config)
CHUNK_SIZE=1048576

# Rate limits (per X-User-Id, sliding window over 1 minute).
# /init defaults to 10/min per the spec; chunks are looser because a
# single large upload needs many PUTs.
RATE_LIMIT_INIT=10
RATE_LIMIT_CHUNK=600

# Which backend tracks "which chunks of upload X have arrived":
#   filesystem (default) — uses the .part files on disk as the index
#   redis                — uses a Redis SET with 24-hour TTL (set REDIS_DSN)
# See ADR-016 in docs/decisions.md.
CHUNK_STATE_BACKEND=filesystem
# REDIS_DSN=redis://localhost:6379
