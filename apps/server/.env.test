# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Relax rate limits so repeated test runs don't hit the 10/min init ceiling.
# The sliding-window counters persist in var/cache/test/ across runs and
# accumulate within the 60-second window when phpunit is run quickly back
# to back — this avoids spurious 429s without changing the application logic.
RATE_LIMIT_INIT=10000
RATE_LIMIT_CHUNK=100000
